## Base44 configuration removed for launch

# ESPN API (No key needed - uses public API)
VITE_ESPN_API_ENABLED=true

# App Configuration
VITE_APP_NAME=MayorWard Sports
VITE_APP_TITLE=Masters 2026 Picks
VITE_APP_DESCRIPTION=Elite golf betting analysis powered by AI

# Analytics
VITE_ANALYTICS_ENABLED=true

# Features
VITE_ENABLE_VIP_SIGNUPS=true
VITE_ENABLE_ADMIN_PANEL=true
VITE_ENABLE_LEADERBOARD_REFRESH=true

# Leaderboard Refresh
VITE_LEADERBOARD_REFRESH_INTERVAL=60000