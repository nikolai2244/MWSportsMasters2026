<IfModule mod_rewrite.c>
	RewriteEngine On
	RewriteBase /

	# Prevent rewrite loops for the SPA entrypoint
	RewriteRule ^index\.html$ - [L]

	# Serve existing files/directories directly
	RewriteCond %{REQUEST_FILENAME} !-f
	RewriteCond %{REQUEST_FILENAME} !-d
	RewriteRule . /index.html [L]
</IfModule>
