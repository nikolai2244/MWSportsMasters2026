{
  "name": "SignupRequest",
  "type": "object",
  "properties": {
    "first_name": {
      "type": "string"
    },
    "last_name": {
      "type": "string"
    },
    "username": {
      "type": "string"
    },
    "email": {
      "type": "string",
      "format": "email"
    },
    "status": {
      "type": "string",
      "enum": [
        "Pending",
        "Approved",
        "Denied"
      ],
      "default": "Pending"
    }
  },
  "required": [
    "first_name",
    "last_name",
    "username",
    "email",
    "status"
  ]
}

